configuration {
    modi: "drun,run,window,ssh,filebrowser";
    show-icons: true;
    icon-theme: "Papirus";
    display-drun: "  Apps";
    display-run: "  Run";
    display-window: "  Windows";
    display-ssh: "  SSH";
    display-filebrowser: "  Files";
    drun-display-format: "{name}";
    window-format: "{w} · {c} · {t}";
    font: "JetBrainsMono Nerd Font 10";
    terminal: "kitty";
}

@theme "current-theme.rasi"
