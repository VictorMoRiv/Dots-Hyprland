* {
bg:           #1e1e2e; /* Base */
    bg-alt:       #313244; /* Surface0 */
    fg:           #cdd6f4; /* Text */
    fg-alt:       #585b70; /* Overlay0 */
    selected:     #f9e2af; /* Blue */
    active:       #a6e3a1; /* Green */
    urgent:       #f38ba8; /* Red */
    
    background-color: transparent;
}
